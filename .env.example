# ===========================================
# Sanity CMS Configuration
# ===========================================
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
SANITY_API_TOKEN=your-sanity-api-token

# ===========================================
# Site Configuration
# ===========================================
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ===========================================
# Facebook Integration (Optional)
# ===========================================
# To display posts from your Facebook page in the news section,
# you need to create a Facebook App and get the following credentials.

# Your Facebook Page ID
# You can find this in your Facebook page's "About" section
# or use the Graph API Explorer
FACEBOOK_PAGE_ID=your-facebook-page-id

# Facebook Page Access Token
# Generate this from the Graph API Explorer with the following permissions:
# - pages_read_engagement
# - pages_show_list
#
# Steps to generate:
# 1. Go to https://developers.facebook.com/tools/explorer/
# 2. Select your app from the dropdown
# 3. Click "Get Token" → "Get Page Access Token"
# 4. Select the permissions above
# 5. Copy the generated token
FACEBOOK_ACCESS_TOKEN=your-facebook-page-access-token

# Optional: Facebook App ID and Secret (for extended features)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ===========================================
# How to Set Up Facebook Integration
# ===========================================
# 1. Go to https://developers.facebook.com/
# 2. Create a new app (Business type recommended)
# 3. Add "Facebook Login" product to your app
# 4. Go to Settings → Basic and note your App ID
# 5. Go to Tools → Graph API Explorer
# 6. Select your app and generate a Page Access Token
# 7. Required permissions: pages_read_engagement, pages_show_list
# 8. Copy the Page ID and Access Token to this file
# 9. Restart your development server

# Note: Short-lived tokens expire in 1-2 hours.
# For production, generate a long-lived token (60 days) or use a System User token.
# See: https://developers.facebook.com/docs/facebook-login/guides/access-tokens
